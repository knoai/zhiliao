# Python / 后端
# --------------------------------------------
# 虚拟环境
venv/
.env/
.venv/
env/
ENV/

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 分发/打包
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/

lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 测试与覆盖率
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

